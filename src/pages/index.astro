<html>
  <head>

    <meta charset="UTF-8">

    <style>
      body {
        margin: 0;
        background: black;
        overflow-x: hidden;
      }

      .scroll {
        height: 400vh;
      }

      .camera {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        overflow: hidden;
      }

      .world {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        will-change: transform;
      }

      .base {
        width: 100%;
        display: block;
      }

      .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        opacity: 0;
        pointer-events: none;
      }

      .veil {
        position: fixed;
        inset: 0;
        background: black;
        opacity: 0;
        pointer-events: none;
        z-index: 5;
      }

      .menu {
  position: fixed;
  top: 18px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;

  display: flex;
  gap: 28px;

  font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
               "Helvetica Neue", Arial, sans-serif;

  font-size: 32px;
  font-weight: 200;
  letter-spacing: 0.06em;
  text-transform: uppercase;

  color: rgba(240,240,240,0.78);
  mix-blend-mode: replace;

  pointer-events: auto;
}

.menu a {
  color: inherit;
  text-decoration: none;
  opacity: 1.0;
  transition: opacity 200ms ease, transform 200ms ease;
}

.menu a:hover {
  opacity: 0.5;
  transform: translateY(-1px);
}

      .menu-vignette {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 140px;
        z-index: 15;
        pointer-events: none;

        background: radial-gradient(
          ellipse at top center,
          rgba(0,0,0,0.70) 0%,
          rgba(0,0,0,0.45) 35%,
          rgba(0,0,0,0.18) 60%,
          rgba(0,0,0,0.00) 100%
        );

        -webkit-mask-image: linear-gradient(
          to bottom,
          rgba(0,0,0,1) 0%,
          rgba(0,0,0,1) 50%,
          rgba(0,0,0,0) 100%
        );

        mask-image: linear-gradient(
          to bottom,
          rgba(0,0,0,1) 0%,
          rgba(0,0,0,1) 50%,
          rgba(0,0,0,0) 100%
        );
      }

      .text-panel {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 850px;
        max-width: 85vw;

        color: rgba(240,240,240,0.95);
        font-size: 28px;
        line-height: 1.6;

        opacity: 0;
        pointer-events: none;
        z-index: 10;

        transition: opacity 220ms ease;
      }

      .text-title {
        font-size: 32px;
        margin-bottom: 10px;
      }

#glitch-layer {
  position: absolute;
  top: 0;
  left: 0;

  width: 100%;
  height: 100%;

  pointer-events: none;
  z-index: 2;
}


.glitch-img {
  position: absolute;
  top: 0;
  left: 0;

  width: 100%;
  height: auto;

  display: block;

  opacity: 0;
  mix-blend-mode: difference;

  animation: glitchFlash 500ms ease-out forwards;
}

      @keyframes glitchFlash {
  0% {
    opacity: 0;
  }

  15% {
    opacity: 1;
  }

  60% {
    opacity: 1;
  }

  100% {
    opacity: 0;
  }
}
    </style>
  </head>

  <body>

    <div class="menu-vignette" id="menuVignette"></div>

    <div class="menu">
      <a href="/about">About</a>
      <a href="/media">Media</a>
      <a href="/research">Research</a>
    </div>

    <div class="scroll"></div>

    <div class="camera">

      <div class="world" id="world">

  <div id="glitch-layer"></div>

  <img class="base" id="baseImage" src="/Mess.jpg" />

  <img class="overlay" id="music" src="/Music-Doodles.png" />
  <img class="overlay" id="philosophy" src="/Philosophy-Doodles.png" />
  <img class="overlay" id="art" src="/Art-Doodles.png" />
  <img class="overlay" id="science" src="/Science-Doodles.png" />

</div>

      <div class="veil" id="veil"></div>

    </div>

    <div class="text-panel" id="text-music">
    <br>
      <div class="text-title">Music</div>
      The Folded Map is a project about Renaissance polyphony. And yet it’s also 
      about philosophy, art and science. It’s the claim that polyphonic music is 
      part of the world, part of knowledge and inextricably boundup in the hisory of modernity. 

    
    </div>

    <div class="text-panel" id="text-philosophy">
      <div class="text-title">Philosophy</div>
       
The Folded Map is about the meanings we construct and curate. With a map we can 
      navigate, evade cul-de-sacs and hunt for treasure. And so it captures not the terrain 
      as such, but our attempts to parse it. In Renaissance music I should hear the discourse 
      on representation. I should hear the Copernican revolution. Beholding polyphony in 
      the age of perspective means placing these objects of study amidst a “paradigm shift”, 
      one that upended what we thought was knowable, how to know it, and how to show it.


    </div>

    <div class="text-panel" id="text-art">
      <div class="text-title">Art</div>
      And yet, almost surprisingly, the colourful canon of Western Polyphony here 
      admits the failure of its own ambitions; efforts to capture, preserve and revive, 
      walk hand in hand with destruction and obfuscation. Corruption meets generation. 
      Written music of this sort continually reveals itself as conceptual art, commenting 
      upon the conditions of its own creation and perilous reception. It’s a picture 
      pretending to be a pipe. 
    </div>

    <div class="text-panel" id="text-science">
      <div class="text-title">Science</div>
      The Folded Map is about the meanings we construct and curate. With a map we can 
      navigate, evade cul-de-sacs and hunt for treasure. And so it captures not the terrain 
      as such, but our attempts to parse it. In Renaissance music I should hear the discourse 
      on representation. I should hear the Copernican revolution. Beholding polyphony in 
      the age of perspective means placing these objects of study amidst a “paradigm shift”, 
      one that upended what we thought was knowable, how to know it, and how to show it.
    </div>

    <script>
      const ids = ["music", "philosophy", "art", "science"];
      const textIds = ["text-music", "text-philosophy", "text-art", "text-science"];

      const world = document.getElementById("world");
      const veil = document.getElementById("veil");
      const baseImage = document.getElementById("baseImage");
const menuVignette = document.getElementById("menuVignette");

function syncGlitchHeight() {
  document.querySelectorAll(".glitch-img").forEach(img => {
    img.style.height = baseImage.offsetHeight + "px";
  });
}

window.addEventListener("resize", syncGlitchHeight);

      const anchors = [0.20, 0.40, 0.60, 0.80];

      function clamp01(x) {
        return Math.max(0, Math.min(1, x));
      }

      function smooth(x) {
        return x * x * (3 - 2 * x);
      }

      function getT() {
        const scrollY = window.scrollY;
        const maxScroll = document.body.scrollHeight - window.innerHeight;
        if (maxScroll <= 0) return 0;
        return scrollY / maxScroll;
      }

      function updateCamera(t) {
        const y = t * (baseImage.offsetHeight - window.innerHeight);
        world.style.transform = `translateY(${-y}px)`;
      }

      function weight(i, t) {
        const dist = Math.abs(t - anchors[i]);
        const range = 0.18;
        return clamp01(1 - dist / range);
      }

      function update() {
        const t = getT();

        updateCamera(t);

        textIds.forEach((id, i) => {
          const el = document.getElementById(id);
          const w = weight(i, t);
          const visible = w > 0.35 ? (w - 0.35) / 0.65 : 0;
          el.style.opacity = clamp01(visible);
        });

        const shift = 0.22;
        const falloff = 1.4;

        ids.forEach((id, i) => {
          const el = document.getElementById(id);
          let w = weight(i, t);
          w = Math.max(0, w - shift);
          w = Math.pow(w, 1 / falloff);
          el.style.opacity = w * 0.95;
        });

        const fadeInEnd = 0.18;
        const fadeOutStart = 0.82;

        let dim = 0;

        if (t < fadeInEnd) {
          dim = smooth(t / fadeInEnd);
        } else if (t > fadeOutStart) {
          dim = smooth((1 - t) / (1 - fadeOutStart));
        } else {
          dim = 1;
        }

        veil.style.opacity = dim * 0.82;
      }

      function loop() {
        update();
        requestAnimationFrame(loop);
      }

      loop();

      const glitchLayer = document.getElementById("glitch-layer");

function syncGlitchSize() {
  glitchLayer.style.height = baseImage.offsetHeight + "px";
}

baseImage.onload = syncGlitchSize;
syncGlitchSize();

window.addEventListener("resize", syncGlitchSize);

const glitchImages = [
  "glitch1.png",
  "glitch2.png",
  "glitch3.png",
  "glitch4.png"
];

function spawnGlitch() {
  const img = document.createElement("img");

  img.src = glitchImages[Math.floor(Math.random() * glitchImages.length)];
  img.className = "glitch-img";

  glitchLayer.appendChild(img);

  syncGlitchHeight();

  setTimeout(() => {
    img.remove();
  }, 180);
}

      function glitchCycle() {
        spawnGlitch();
        const next = Math.random() * (1200 - 300) + 300;
        setTimeout(glitchCycle, next);
      }

      glitchCycle();
    </script>

  </body>
</html>